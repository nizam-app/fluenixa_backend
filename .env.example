# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/flunexia

# Frontend + mobile (comma-separated origins, or "*" for dev only)
# Web: http://localhost:5173
# Capacitor: capacitor://localhost
# Expo/RN: http://localhost:8081
CLIENT_ORIGIN=http://localhost:5173

# JWT — generate with `npm run gen-secret`, must be 32+ chars in production.
JWT_SECRET=replace-with-output-of-npm-run-gen-secret
JWT_EXPIRES_IN=7d

# Admin bootstrap — leave blank in dev; required in production.
ADMIN_BOOTSTRAP_KEY=

# Uploads — image files are streamed to Cloudinary.
# Get credentials from https://console.cloudinary.com/ → "Product Environment Credentials".
# Use EITHER the one-line URL (recommended) OR the three split values below.
# The image upload endpoint returns 503 until one of the two forms is set.

# Option A — one-line URL (auto-detected by the Cloudinary SDK):
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Option B — explicit split values:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Hard cap on uploaded image size in bytes (5 MB by default).
MAX_UPLOAD_BYTES=5242880

# Legacy: directory served at /uploads for any pre-Cloudinary local files.
# Safe to leave at the default — only used to keep old image URLs reachable.
UPLOAD_DIR=uploads

# Set to "true" behind a reverse proxy (Heroku, Render, nginx) so rate limiting
# and req.ip see the real client address.
TRUST_PROXY=false
